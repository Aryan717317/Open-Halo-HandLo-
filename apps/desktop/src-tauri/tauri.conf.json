{
  "build": {
    "beforeDevCommand": "cd frontend && npm run dev",
    "beforeBuildCommand": "cd frontend && npm run build",
    "devPath": "http://localhost:5173",
    "distDir": "../frontend/build"
  },
  "package": {
    "productName": "GestureShare",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": { "open": true },
      "dialog": { "open": true, "save": false },
      "fs": {
        "readFile": true,
        "writeFile": true,
        "readDir": true,
        "scope": ["$DOWNLOAD/*", "$DOCUMENT/*", "$HOME/*"]
      },
      "path": { "all": true }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.gestureshare.app",
      "icon": ["icons/icon.png"]
    },
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob:; media-src 'self' blob:; connect-src 'self' https://cdn.jsdelivr.net"
    },
    "windows": [{
      "label": "main",
      "title": "GestureShare",
      "width": 1200,
      "height": 800,
      "minWidth": 900,
      "minHeight": 600,
      "resizable": true,
      "fullscreen": false
    }]
  }
}
